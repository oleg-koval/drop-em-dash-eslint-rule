    "url": "git+https://github.com/oleg-koval/drop-em-dash-eslint-rule.git"
  },
  "bugs": {
    "url": "https://github.com/oleg-koval/drop-em-dash-eslint-rule/issues"
  },
  "homepage": "https://oleg-koval.github.io/drop-em-dash-eslint-rule/",
